{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!node_modules",
      "!.recovery-backups",
      "!.git",
      "!artifacts",
      "!adapters/**/bin",
      "!adapters/**/obj",
      "!**/.DS_Store"
    ]
  }
}
